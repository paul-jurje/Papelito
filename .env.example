# Database file path for the SQLite database. Relative paths are resolved
# against the apps/api working directory. The default `papelito.db` is what
# the dev server and migrations target out of the box.
DATABASE_URL=papelito.db

# Secret used by `express-session` to sign session cookies. Set this to a long
# random string in production — anyone who knows it can forge session cookies.
SESSION_SECRET=change-me-in-production

# Stripe test-mode secret key from https://dashboard.stripe.com/test/apikeys.
# The server refuses to start without this. Use the `sk_test_...` prefix.
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret printed by the Stripe CLI when you run
# `stripe listen --forward-to localhost:3000/api/billing/webhook` (or copied
# from the dashboard for a deployed endpoint). Used to verify the HMAC
# signature Stripe sends with every webhook event.
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price id for the monthly subscription plan (`price_...`). Create the
# product + recurring price in the Stripe test dashboard, then paste the
# price id here. The checkout endpoint uses this to build the line item.
STRIPE_PRICE_ID=price_...

# Port the Express API binds to. The Vite frontend (apps/web) expects the API
# on port 3000 by default in development.
PORT=3000

# Origin of the frontend web app, used to configure CORS. The browser will
# only send the session cookie on cross-origin requests when this origin is
# the configured CORS origin AND `credentials: true` is enabled. Defaults to
# `http://localhost:5173` (the Vite dev server). In production set this to
# the deployed frontend URL, e.g. `https://app.example.com`.
WEB_ORIGIN=http://localhost:5173
